VITE_SUPABASE_URL="YOUR_SUPABASE_URL"
VITE_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"

# Cloudinary credentials for direct frontend uploads
# You need to create an UNSIGNED upload preset in Cloudinary settings.
# CLOUDINARY_CLOUD_NAME can be found in your Cloudinary dashboard.
# CLOUDINARY_UPLOAD_PRESET is the name of the unsigned preset you created (e.g., 'photo_hub_compression').
VITE_CLOUDINARY_CLOUD_NAME="YOUR_CLOUDINARY_CLOUD_NAME"
VITE_CLOUDINARY_UPLOAD_PRESET="YOUR_CLOUDINARY_UPLOAD_PRESET"

# Supabase Edge Function secrets (for cloudinary-delete function)
# These are NOT exposed to the frontend.
CLOUDINARY_API_KEY="YOUR_CLOUDINARY_API_KEY"
CLOUDINARY_API_SECRET="YOUR_CLOUDINARY_API_SECRET"
CLOUDINARY_CLOUD_NAME="YOUR_CLOUDINARY_CLOUD_NAME" # Also needed for server-side delete
SUPABASE_URL="YOUR_SUPABASE_URL"
SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"
SUPABASE_SERVICE_ROLE_KEY="YOUR_SUPABASE_SERVICE_ROLE_KEY"
SUPABASE_DB_URL="YOUR_SUPABASE_DB_URL"